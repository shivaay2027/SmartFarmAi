PORT=4001

# ─── MongoDB (optional — enables historical price persistence & cron‑job) ──────
# Without this, the app falls back gracefully to mock historical data.
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=krishi_route

# ─── Optional overrides ─────────────────────────────────────────────────────── 
# Uncomment to pin fuel price (₹/litre) and skip live fetch:
# FUEL_PRICE=90

# Mapbox Directions API token (for real road distances; OSRM is free fallback)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
